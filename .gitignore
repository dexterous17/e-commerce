/backend/node_modules/
/frontend/node_modules/
/node_modules/

# Package manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
# Per-system env (templates committed as env/<system>/.env.example)
/env/**/.env
/env/**/.env.*
!/env/**/.env.example
!/env/**/.env.sample
!/env/**/.env.production.example

# Deploy bundle from scripts/build-for-live.mjs (merged .env — do not commit)
/build/

# Docker Compose local overrides (ports, bind mounts, secrets)
docker-compose.override.yml
# Legacy paths (still supported by backend/config/loadEnv.js)
aws/.env
aws/.env.*
database/.env
database/.env.*
backend/.env
backend/.env.*
backend/db/.env
backend/db/.env.production
!backend/db/.env.example
!backend/db/.env.production.example
backend/data/*.sqlite
backend/data/*.sqlite-*
frontend/.env
frontend/.env.*
!.env.example
!.env.sample

# Lightsail: optional strict host key file (populate with ssh-keyscan -t ed25519)
/deploy/lightsail/known_hosts

# Secrets and local certificates/keys
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/*.txt
!secrets/*.example
!secrets/README.md

# Python (e.g. deploy/lightsail helpers)
__pycache__/
*.py[cod]
*$py.class

# Accidental duplicate files (e.g. macOS "Copy" → `name 2.json`)
**/* 2.json

# Cursor / agent debug session logs (local only)
.cursor/debug*.log

# OS / editor
.DS_Store
Thumbs.db
.idea/

# Product images synced from S3 (large; keep backend/upload/.gitkeep only)
/backend/upload/*
!/backend/upload/.gitkeep

# Frontend build output
/frontend/dist/
/frontend/build/
/frontend/.vite/

# Tests and coverage (local only)
coverage/
.nyc_output/
*.lcov

# Tooling caches
.eslintcache

# Playwright (local HTML report and run artifacts)
/frontend/playwright-report/
/frontend/test-results/
