{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@paypal/react-paypal-js": "^8.9.2",
    "@redux-devtools/extension": "^4.0.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^11.2.7",
    "@testing-library/user-event": "^12.8.3",
    "axios": "^1.14.0",
    "gh-pages": "^6.3.0",
    "react": "^18.3.1",
    "react-bootstrap": "^1.6.8",
    "react-dom": "^18.3.1",
    "react-redux": "^8.1.3",
    "react-router-bootstrap": "^0.26.3",
    "react-router-dom": "^6.28.0",
    "redux": "^4.2.1",
    "redux-thunk": "^2.4.2",
    "web-vitals": "^1.1.2"
  },
  "scripts": {
    "check:vite-config": "node --check vite.config.js",
    "start": "node --check vite.config.js && vite",
    "dev": "node --check vite.config.js && vite",
    "build": "node --check vite.config.js && vite build",
    "preview": "vite preview",
    "test": "node -e \"console.log('No tests configured')\"",
    "lint": "eslint src",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "vite": "^8.0.3"
  }
}
