{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@paypal/react-paypal-js": "^9.2.0",
    "@redux-devtools/extension": "^4.0.0",
    "axios": "^1.16.0",
    "gh-pages": "^6.3.0",
    "react": "^19.2.6",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.6",
    "react-redux": "^9.2.0",
    "react-router-bootstrap": "^0.26.3",
    "react-router-dom": "^7.15.0",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0"
  },
  "scripts": {
    "check:vite-config": "node --check vite.config.js",
    "start": "node --check vite.config.js && concurrently -n api,web -c blue,green \"npm run start --prefix ../backend\" \"node scripts/wait-for-api.mjs && vite\"",
    "dev": "node --check vite.config.js && concurrently -n api,web -c blue,green \"npm run server --prefix ../backend\" \"node scripts/wait-for-api.mjs && vite\"",
    "start:vite-only": "node --check vite.config.js && vite",
    "build": "node --check vite.config.js && vite build",
    "preview": "vite preview",
    "test": "node -e \"console.log('No tests configured')\"",
    "lint": "eslint src",
    "test:e2e": "playwright test",
    "test:e2e:demo-videos": "playwright test --project=demo-videos",
    "test:e2e:install": "playwright install",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "vite": "^8.0.10"
  }
}
