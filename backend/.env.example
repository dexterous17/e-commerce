NODE_ENV=production
# Default 5002 avoids macOS AirPlay on 5000 and stray listeners on 5001. Vite proxies here (frontend/.env).
# Docker Compose publishes the *container* API on host BACKEND_PORT (default 5004 in root .env.example).
PORT=5002
SERVE_FRONTEND=false

# Postgres: either set variables below, or keep them in repo-root database/.env (loaded automatically before this file).
# DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/ecommerce

# Backend and PostgreSQL run on the same server.
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=ecommerce
# Matches docker-compose default POSTGRES_USER unless you override it.
PGUSER=ecommerce
PGPASSWORD=replace-me-with-your-postgres-password
PGSSLMODE=disable

JWT_SECRET=replace-me-with-a-long-random-jwt-secret
PAYPAL_CLIENT_ID=

# Optional S3-backed product image settings.
# Credentials can live here or in repo-root aws/.env (loaded automatically before this file).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=bucket-7i9ax7
AWS_S3_PUBLIC_BASE_URL=https://bucket-7i9ax7.s3.us-east-1.amazonaws.com
AWS_S3_PREFIX=products
# When true (default), product/order APIs return /api/media/s3?key=... and the backend streams objects from S3.
# AWS_S3_IMAGE_PROXY=false
