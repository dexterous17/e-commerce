# Copy to `backend/db/.env` (do not commit `.env`).
# Loaded before env/aws/.env and env/backend/.env (see backend/config/loadEnv.js).
# Relative paths resolve from the backend/ directory (where `node server.js` runs).

# Default if unset: backend/data/ecommerce.sqlite
SQLITE_DATABASE_PATH=data/ecommerce.sqlite
