# Copy to `backend/db/.env` (do not commit `.env`).
# This file wins over env/database/.env when present (first match in repoEnvPaths.js).

# Hosted or local PostgreSQL — prefer DATABASE_URL (sslmode=require is honored for RDS, Neon, etc.)
# For local Node on the host + Postgres in Docker (port 5432 on localhost), use 127.0.0.1, not
# the Compose service hostname "postgres" (ENOTFOUND from the host).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Or separate vars (no DATABASE_URL):
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=ecommerce
# PGPASSWORD=your-secret
# PGDATABASE=ecommerce
