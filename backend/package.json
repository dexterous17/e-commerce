{
  "name": "harshil-ecommerce",
  "type": "module",
  "version": "1.0.0",
  "description": "Harshil",
  "main": "server.js",
  "scripts": {
    "build": "npm ci --omit=dev",
    "build:docker": "docker build -f Dockerfile -t ecommerce-backend:latest ..",
    "token:demo": "node scripts/demo-generate-token.mjs",
    "env:init": "node scripts/init-env.mjs",
    "env:debug": "node scripts/debug-env.mjs",
    "check": "node scripts/check-env.mjs",
    "start": "node scripts/assert-listen-port-free.mjs && node scripts/check-env.mjs && node server.js",
    "server": "node scripts/assert-listen-port-free.mjs && node scripts/check-env.mjs && nodemon server.js",
    "server:inspect": "node scripts/assert-listen-port-free.mjs && node scripts/check-env.mjs && nodemon --inspect=9230 server.js",
    "server:debug": "node scripts/assert-listen-port-free.mjs && node scripts/check-env.mjs && cross-env DEBUG=ecom:* nodemon server.js",
    "client": "npm run start:vite-only --prefix ../frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "images:download": "node scripts/downloadProductImages.js",
    "images:sync:s3-to-upload": "node scripts/syncS3ToLocalUpload.js",
    "images:upload:s3-manifest": "node scripts/uploadProductsToS3Manifest.js",
    "data:import": "node seeder.js",
    "data:import:s3": "node seederS3.js",
    "data:import:s3:manifest": "node seederS3FromManifest.js",
    "data:import:local-upload-manifest": "node seederLocalUploadFromManifest.js",
    "data:destroy": "node seeder.js -d",
    "data:destroy:s3": "node seederS3.js -d"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "bcryptjs": "^3.0.3",
    "colors": "^1.4.0",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.14"
  }
}
