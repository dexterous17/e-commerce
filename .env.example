# --- Docker Compose (docker-compose.yml) published ports ---
# Postgres: 127.0.0.1:5432 -> 5432 (fixed in compose; not overridable here)
# Frontend (nginx): host FRONTEND_PORT -> container 80  -> http://localhost:${FRONTEND_PORT}
# Backend (Node):   host BACKEND_PORT   -> container 5000 -> http://127.0.0.1:${BACKEND_PORT}
# Default BACKEND_PORT=5004 avoids clashing with host `npm start` (backend/.env PORT=5002 + Vite).
# If you only use Docker for the API, set BACKEND_PORT=5002 (or any free port) consistently in tooling.
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
FRONTEND_PORT=3000
BACKEND_PORT=5004
PUBLIC_URL=/
PAYPAL_CLIENT_ID=
AWS_REGION=
AWS_S3_BUCKET_NAME=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_PREFIX=products
