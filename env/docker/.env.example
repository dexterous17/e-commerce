# Copy to repo-root `.env` for `docker compose` variable substitution (Compose reads ./.env next to docker-compose.yml).
# Template lives here as env/docker/.env.example so all environment templates stay under env/.

# --- Published ports ---
# Frontend (nginx): host FRONTEND_PORT -> container 80  -> http://localhost:${FRONTEND_PORT}
# Backend (Node):   host BACKEND_PORT   -> container 5000 -> http://127.0.0.1:${BACKEND_PORT}
# Default BACKEND_PORT=5004 avoids clashing with host `npm start` (env/backend/.env PORT=5002 + Vite).
# If you only use Docker for the API, set BACKEND_PORT=5002 (or any free port) consistently in tooling.
FRONTEND_PORT=3000
BACKEND_PORT=5004
PUBLIC_URL=/
# docker-compose.yml — Postgres container + DATABASE_URL for backend
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce
PAYPAL_CLIENT_ID=
# S3: matches env/aws/.env.example (non-secret). docker-compose.yml uses the same fallbacks.
# For GetObject (/api/media/s3), put AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY in env/aws/.env — loaded via env_file.
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=bucket-7i9ax7
AWS_S3_PUBLIC_BASE_URL=https://bucket-7i9ax7.s3.us-east-1.amazonaws.com
AWS_S3_PREFIX=products
# MinIO (local S3 only; docker-compose `minio` + `minio-init`). API on MINIO_API_PORT; console on MINIO_CONSOLE_PORT.
# Your production bucket is created in AWS separately; sync: ./scripts/sync-minio-to-s3.sh
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=change-me
# Backend → MinIO (same Docker network): in env/aws/.env set
#   AWS_S3_ENDPOINT_URL=http://minio:9000
#   AWS_S3_FORCE_PATH_STYLE=true
#   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY = same as MINIO_ROOT_* above.
# AWS_S3_BUCKET_NAME / AWS_S3_PREFIX should match what you use on AWS so keys stay aligned.
# Browsers still use AWS_S3_PUBLIC_BASE_URL and/or the image proxy unless you point URLs at MinIO explicitly.
