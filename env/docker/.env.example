# Copy to repo-root `.env` for `docker compose` variable substitution (Compose reads ./.env next to docker-compose.yml).
# Template lives here as env/docker/.env.example so all environment templates stay under env/.

# --- Published ports ---
# Frontend (nginx): host FRONTEND_PORT -> container 80  -> http://localhost:${FRONTEND_PORT}
# Backend (Node):   host BACKEND_PORT   -> container 5000 -> http://127.0.0.1:${BACKEND_PORT}
# Default BACKEND_PORT=5004 avoids clashing with host `npm start` (env/backend/.env PORT=5002 + Vite).
# If you only use Docker for the API, set BACKEND_PORT=5002 (or any free port) consistently in tooling.
FRONTEND_PORT=3000
BACKEND_PORT=5004
PUBLIC_URL=/
PAYPAL_CLIENT_ID=
# S3: matches env/aws/.env.example (non-secret). docker-compose.yml uses the same fallbacks.
# For GetObject (/api/media/s3), put AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY in env/aws/.env — loaded via env_file.
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=bucket-7i9ax7
AWS_S3_PUBLIC_BASE_URL=https://bucket-7i9ax7.s3.us-east-1.amazonaws.com
AWS_S3_PREFIX=products
