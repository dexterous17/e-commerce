# Copy to `.env` (gitignored). Used by:
# - backend/config/loadEnv.js on host `npm start`
# - docker-compose backend `env_file` so /api/media/s3 can call S3 (private buckets).
#
# Never commit real keys.

# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# S3-backed product images (non-secret bucket/region config can live here or in Compose)
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=bucket-7i9ax7
AWS_S3_PUBLIC_BASE_URL=https://bucket-7i9ax7.s3.us-east-1.amazonaws.com
AWS_S3_PREFIX=products
# When true (default), product/order APIs return /api/media/s3?key=... and the backend streams objects from S3.
# AWS_S3_IMAGE_PROXY=false

# ---------------------------------------------------------------------------
# Optional: EC2 / networking reference (not read by the backend; for your notes)
# ---------------------------------------------------------------------------
# AWS_EC2_INSTANCE_NAME=my-instance
# AWS_EC2_AVAILABILITY_ZONE=us-east-1a
# AWS_EC2_INSTANCE_TYPE_CATEGORY=general-purpose
# AWS_EC2_NETWORKING_TYPE=dual-stack
# AWS_EC2_PUBLIC_IPV4=
# AWS_EC2_PRIVATE_IPV4=
# AWS_EC2_PUBLIC_IPV6=
# AWS_EC2_ELASTIC_PUBLIC_IPV4=
# AWS_EC2_ELASTIC_NAME=
# AWS_EC2_SSH_PUBLIC_KEY="ssh-rsa AAAA... comment"
