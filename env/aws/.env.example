# Copy to `env/aws/.env` (gitignored). Used by:
# - backend/config/loadEnv.js on host `npm start`
# - docker-compose backend `env_file` so /api/media/s3 can call S3 (private buckets).
# - scripts/sync-minio-to-s3.sh (push objects from local MinIO → your real AWS bucket).
#
# Never commit real keys.
#
# --- AWS vs local MinIO (typical split) ---
# - AWS: Create the bucket and IAM user/role yourself in the AWS console. Put region, bucket name,
#   public base URL, and API keys here. The sync script only writes objects into that existing bucket;
#   it does not create the bucket on AWS.
# - Local: Docker Compose runs MinIO; `minio-init` creates a bucket *on MinIO only* (same name/prefix
#   as below so object keys match). Point the backend at MinIO with AWS_S3_ENDPOINT_URL (see below);
#   use MINIO_ROOT_* values as AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY when talking to MinIO.

# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# S3-backed product images (AWS bucket you created + credentials above)
# Local MinIO (host Node + seeders): use 127.0.0.1 and compose MINIO_API_PORT (default 9010). Path-style public URL
# must include the bucket path so stored keys round-trip: http://127.0.0.1:9010/<AWS_S3_BUCKET_NAME>
# AWS_S3_ENDPOINT_URL=http://127.0.0.1:9010
# AWS_S3_FORCE_PATH_STYLE=true
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_S3_PUBLIC_BASE_URL=http://127.0.0.1:9010/bucket-7i9ax7
# In-container backend only: AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=bucket-7i9ax7
AWS_S3_PUBLIC_BASE_URL=https://bucket-7i9ax7.s3.us-east-1.amazonaws.com
AWS_S3_PREFIX=products
# Route all product image requests through the backend proxy (GET /api/media/s3?key=...) so the
# browser never fetches directly from S3. Set to false only if you want direct S3 public URLs.
AWS_S3_IMAGE_PROXY=true
# Force off: AWS_S3_IMAGE_PROXY=false

# ---------------------------------------------------------------------------
# Optional: EC2 / networking reference (not read by the backend; for your notes)
# ---------------------------------------------------------------------------
# AWS_EC2_INSTANCE_NAME=my-instance
# AWS_EC2_AVAILABILITY_ZONE=us-east-1a
# AWS_EC2_INSTANCE_TYPE_CATEGORY=general-purpose
# AWS_EC2_NETWORKING_TYPE=dual-stack
# AWS_EC2_PUBLIC_IPV4=
# AWS_EC2_PRIVATE_IPV4=
# AWS_EC2_PUBLIC_IPV6=
# AWS_EC2_ELASTIC_PUBLIC_IPV4=
# AWS_EC2_ELASTIC_NAME=
# AWS_EC2_SSH_PUBLIC_KEY="ssh-rsa AAAA... comment"
