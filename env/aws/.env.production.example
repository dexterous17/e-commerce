# Copy to env/aws/.env.production (gitignored) with your live bucket and keys.
# Merged into build/deploy/.env by scripts/build-for-live.mjs.

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-live-bucket
AWS_S3_PUBLIC_BASE_URL=https://your-live-bucket.s3.us-east-1.amazonaws.com
AWS_S3_PREFIX=products
