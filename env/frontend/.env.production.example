# Copied to .env.production by scripts/build-for-live.mjs when that file is missing.
# Production URLs differ from dev (localhost:5173) and from Playwright defaults — use your
# live storefront hostname; same-origin /api is typical:
# Leave empty: browser calls https://<storefront>/api/... and host nginx proxies to the API
# container (see deploy/lightsail/ecommerce-domains.conf). Set a full URL only for split-domain
# with TLS on the API host, e.g. VITE_API_ORIGIN=https://backend.example.com
VITE_API_ORIGIN=
