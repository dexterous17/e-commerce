# --- Development (Vite dev, mode=development) ---
# Proxies /api, /uploads, /upload → backend. Match env/backend/.env PORT (default 5002).
# Not VITE_* on purpose: proxy URL must not ship in the browser bundle.
DEV_PROXY_TARGET=http://localhost:5002
# Optional templates: .env.development.example, .env.test.example, .env.production.example

# --- Production client bundle (vite build, mode=production) ---
# Empty: browser uses same-origin /api (e.g. nginx on the storefront host).
# Non-empty: split API host, e.g. VITE_API_ORIGIN=https://api.yourdomain.com
# Docker compose may pass VITE_API_ORIGIN at image build time; see docker-compose.yml build args.

# --- E2E / automated tests (Playwright; not loaded by Vite) ---
# PLAYWRIGHT_BASE_URL=http://localhost:5173
# E2E_API_ORIGIN=http://127.0.0.1:5002
