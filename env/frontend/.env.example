# Vite dev server proxies /api and /uploads here. Must match env/backend/.env PORT (default 5002).
# From frontend/: npm start and npm dev also start the API via ../backend (see frontend/package.json).
# Use npm run start:vite-only only if the API is already running separately.
# Not VITE_* on purpose: only VITE_-prefixed keys belong in client bundles (import.meta.env).
DEV_PROXY_TARGET=http://localhost:5002
