# Playwright / Node E2E — not read by Vite. Export in CI or `source` before `npm run test:e2e`.
#
# Local automated tests (default): browser hits Vite, API health checks hit the Node backend.
PLAYWRIGHT_BASE_URL=http://localhost:5173
E2E_API_ORIGIN=http://127.0.0.1:5002
#
# Production smoke (see package.json test:e2e:demo-videos:prod): real storefront + same host /api.
# PLAYWRIGHT_SKIP_WEBSERVER=1
# PLAYWRIGHT_BASE_URL=https://your-production-store.example.com
# E2E_API_ORIGIN=https://your-production-store.example.com
