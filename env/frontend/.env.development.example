# Vite `mode=development` — copy to .env.development or .env.development.local (gitignored).
# Storefront: http://localhost:5173 (Vite). API: proxied from DEV_PROXY_TARGET (not in the browser bundle).

DEV_PROXY_TARGET=http://localhost:5002

# Leave unset or empty so the app uses same-origin /api (Vite proxy → DEV_PROXY_TARGET).
# Set only if you intentionally test split-origin from dev, e.g.:
# VITE_API_ORIGIN=https://staging-api.example.com
