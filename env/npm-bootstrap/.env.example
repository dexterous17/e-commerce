# Used by docker-compose.nginx-proxy-manager.yml service `npm-bootstrap` (optional env_file).
# Copy to `.env` in this folder — the real file is gitignored.

# NPM admin login (defaults: admin@example.com / changeme when NPM_USE_DEFAULT_CREDENTIALS=1)
# NPM_ADMIN_EMAIL=admin@example.com
# NPM_ADMIN_PASSWORD=

# If NPM_ADMIN_PASSWORD is empty, set to 1 to use the factory default password once, then
# change the admin password in the NPM UI and set NPM_ADMIN_PASSWORD here (set back to 0).
# NPM_USE_DEFAULT_CREDENTIALS=1

# Domains and upstreams (defaults match harshildex.com + compose service names)
# NPM_STOREFRONT_DOMAIN=ecommerce.harshildex.com
# NPM_API_DOMAIN=backend.ecommerce.harshildex.com
# NPM_FORWARD_STOREFRONT=frontend
# NPM_FORWARD_STOREFRONT_PORT=80
# NPM_FORWARD_API=backend
# NPM_FORWARD_API_PORT=5000

# Optional automatic TLS via Let's Encrypt. If NPM_AUTO_TLS=1, bootstrap reuses an existing
# certificate that already covers both domains or requests a new one and attaches it to both
# proxy hosts. If NPM_LETSENCRYPT_EMAIL is unset, bootstrap falls back to NPM_ADMIN_EMAIL when
# that is not the placeholder admin@example.com.
# NPM_AUTO_TLS=1
# NPM_LETSENCRYPT_EMAIL=you@example.com
# NPM_FORCE_SSL=1
# NPM_HSTS_ENABLED=0
# NPM_HSTS_SUBDOMAINS=0

# Portainer domain (set to empty string to skip)
# NPM_PORTAINER_DOMAIN=portainer.harshildex.com
# NPM_FORWARD_PORTAINER=portainer
# NPM_FORWARD_PORTAINER_PORT=9000
