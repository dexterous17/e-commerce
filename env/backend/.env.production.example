# Optional: copy to env/backend/.env.production (gitignored) for live API settings.
# Included in build/deploy/.env merge when present (after database + aws).

NODE_ENV=production
PORT=5002
SERVE_FRONTEND=false

JWT_SECRET=replace-with-long-random-secret

# Storefront origin(s) for CORS when the SPA is not same-origin as the API
# CORS_ORIGIN=https://ecommerce.harshildex.com

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

