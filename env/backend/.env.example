NODE_ENV=production
# Default 5002 avoids macOS AirPlay on 5000 and stray listeners on 5001. Vite proxies here (env/frontend/.env).
# Docker Compose publishes the *container* API on host BACKEND_PORT (default 5004 in env/docker/.env.example).
PORT=5002
SERVE_FRONTEND=false

# Postgres credentials live in env/database/.env (loaded before this file).
# AWS / S3 credentials and bucket settings live in env/aws/.env (loaded before this file).

JWT_SECRET=replace-me-with-a-long-random-jwt-secret

# PayPal (live: PAYPAL_MODE=live or production; default is sandbox API)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Optional: only for local dev without PayPal API verification (never use in production)
# PAYPAL_SKIP_VERIFY=true

# Webhook URL in PayPal dashboard: https://your-api/api/webhooks/paypal
# PAYPAL_WEBHOOK_ID=

# Production: comma-separated allowed browser origins (e.g. https://shop.example.com,https://www.shop.example.com).
# If the SPA is on another hostname than the API (e.g. shop on https://ecommerce.example.com and API on https://backend.ecommerce.example.com), set:
# CORS_ORIGIN=https://ecommerce.example.com
# CORS_ORIGIN=

# Behind a reverse proxy (Docker/nginx): trust X-Forwarded-* for rate limits and IPs
# TRUST_PROXY=true
# TRUST_PROXY_HOPS=1

# Optional rate limits (defaults are safe)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=400
# AUTH_RATE_LIMIT_MAX=40
# REGISTER_RATE_LIMIT_MAX=25
