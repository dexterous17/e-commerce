# Legacy path: used when backend/db/.env does not exist (see backend/config/repoEnvPaths.js).
# For new setups prefer: cp backend/db/.env.example backend/db/.env
#
# When the API runs on your machine (npm / nodemon) and Postgres runs in Docker with ports
# published to the host, use 127.0.0.1 — not the service name "postgres" (that only resolves
# inside the Compose network).
#
# DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/ecommerce
