# Copy to `.env` and set real credentials. Do not commit `.env`.
# Backend loads env/database/.env (or legacy database/.env) before env/backend/.env.
#
# Docker on the same VM as Postgres: use host.docker.internal instead of 127.0.0.1 so the
# backend container reaches the host Postgres (see docker-compose.lightsail.yml extra_hosts).

DATABASE_URL=postgresql://ecommerce_app:replace-me@127.0.0.1:5432/ecommerce

PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=ecommerce
PGUSER=ecommerce_app
PGPASSWORD=replace-me
PGSSLMODE=disable

# --- Same VM, Postgres on host, API in Docker (Lightsail compose) ---
# DATABASE_URL=postgresql://ecommerce_app:replace-me@host.docker.internal:5432/ecommerce
# PGHOST=host.docker.internal
