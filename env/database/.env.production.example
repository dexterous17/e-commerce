# Copy to env/database/.env.production (gitignored) with your live Postgres URL.
# Merged into build/deploy/.env by scripts/build-for-live.mjs when both this and
# env/aws/.env.production exist.

DATABASE_URL=postgresql://USER:PASSWORD@YOUR_LIVE_DB_HOST:5432/ecommerce

PGHOST=YOUR_LIVE_DB_HOST
PGPORT=5432
PGDATABASE=ecommerce
PGUSER=USER
PGPASSWORD=PASSWORD
PGSSLMODE=require
