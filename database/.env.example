# Copy to `.env` and set real credentials. Do not commit `.env`.
# Backend loads `backend/.env` — add DATABASE_URL there too if the API should use this URL.

DATABASE_URL=postgresql://ecommerce_app:replace-me@127.0.0.1:5432/ecommerce

PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=ecommerce
PGUSER=ecommerce_app
PGPASSWORD=replace-me
